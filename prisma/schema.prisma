generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CREATOR
  NETWORK
  BRAND
  ADMIN
  AGENCY
  ACCOUNT_MANAGER
}

enum OrderStatus {
  DRAFT
  OPEN
  ASSIGNED
  IN_PROGRESS
  DELIVERED
  REVISION
  APPROVED
  COMPLETED
  DISPUTED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  HELD
  RELEASED
  REFUNDED
  FAILED
}

enum OrderType {
  SHORT_VIDEO
  LIVE
  COMBO
}

enum DeliveryType {
  SHORT_VIDEO
  LIVE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String
  role          UserRole?
  avatar        String?
  image         String?
  emailVerified DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  creator         Creator?
  network         CreatorNetwork?
  brand           Brand?
  agency          Agency?
  accountManager  AccountManager?
  tickets         SupportTicket[] @relation("TicketCreator")
  assignedTickets SupportTicket[] @relation("TicketAssignee")
  notifications   Notification[]

  @@index([role])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Creator {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tiktokUsername String  @unique
  tiktokId       String? @unique
  tiktokVerified Boolean @default(false)

  followerCount  Int   @default(0)
  avgViews       Int   @default(0)
  engagementRate Float @default(0)
  totalLikes     Int   @default(0)
  totalVideos    Int   @default(0)

  score            Float @default(0)
  tier             Int   @default(1)
  pricePerThousand Float @default(2.0)

  bio            String?
  categories     CreatorCategory[]
  portfolioLinks String[]          @default([])

  stripeAccountId String?
  stripeOnboarded Boolean @default(false)

  networkId String?
  network   CreatorNetwork? @relation(fields: [networkId], references: [id])

  supportsLive       Boolean @default(false)
  supportsShortVideo Boolean @default(true)

  metricsUpdatedAt DateTime?
  orderAssignments OrderAssignment[]
  aiAnalyses       AiCreatorAnalysis[]
  agencyCreators   AgencyCreator[]
  internalNotes    InternalNote[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([score])
  @@index([tier])
  @@index([networkId])
}

model CreatorNetwork {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName String
  website     String?
  description String?

  stripeAccountId String?
  stripeOnboarded Boolean @default(false)

  creators         Creator[]
  orderAssignments OrderAssignment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Brand {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName String
  website     String?
  industry    String?
  description String?
  logo        String?

  orders              Order[]
  agencyBrands        AgencyBrand[]
  accountManagerBrand AccountManagerBrand[]
  internalNotes       InternalNote[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Category {
  id       String            @id @default(cuid())
  name     String            @unique
  slug     String            @unique
  icon     String?
  creators CreatorCategory[]
  orders   Order[]

  @@index([slug])
}

model CreatorCategory {
  creatorId  String
  categoryId String
  creator    Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([creatorId, categoryId])
}

model Order {
  id      String @id @default(cuid())
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  title       String
  description String
  brief       String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  type OrderType @default(SHORT_VIDEO)

  // SHORT_VIDEO pricing (CPM-based)
  impressionTarget Int
  budget           Float
  cpmRate          Float

  // LIVE pricing (flat fee per stream)
  liveFlatFee     Float?
  liveMinDuration Int?
  liveGuidelines  String?

  status      OrderStatus @default(DRAFT)
  maxCreators Int         @default(1)

  stripePaymentId String?
  paymentStatus   PaymentStatus @default(PENDING)

  agencyId     String?
  agency       Agency?           @relation(fields: [agencyId], references: [id])

  assignments      OrderAssignment[]
  deliveries       Delivery[]
  transactions     Transaction[]
  internalNotes    InternalNote[]
  aiDeliveryAnalyses AiDeliveryAnalysis[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  expiresAt    DateTime?

  @@index([status])
  @@index([brandId])
  @@index([categoryId])
  @@index([agencyId])
}

model OrderAssignment {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  creatorId String?
  creator   Creator?        @relation(fields: [creatorId], references: [id])
  networkId String?
  network   CreatorNetwork? @relation(fields: [networkId], references: [id])

  status      OrderStatus @default(ASSIGNED)
  acceptedAt  DateTime    @default(now())
  completedAt DateTime?

  @@index([orderId])
  @@index([creatorId])
}

model Delivery {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  deliveryType DeliveryType @default(SHORT_VIDEO)

  tiktokLink    String
  tiktokLinks   String[] @default([])
  screenshotUrl String?
  screenshots   String[] @default([])

  // SHORT_VIDEO metrics
  impressions Int?
  views       Int?
  likes       Int?
  comments    Int?
  shares      Int?

  // LIVE metrics
  streamDuration       Int?
  peakViewers          Int?
  avgConcurrentViewers Int?
  chatMessages         Int?
  giftsValue           Float?

  notes String?

  submittedAt     DateTime  @default(now())
  reviewedAt      DateTime?
  approved        Boolean?
  rejectionReason String?
  aiAnalyses      AiDeliveryAnalysis[]

  @@index([orderId])
}

model Transaction {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  amount        Float
  platformFee   Float
  creatorPayout Float
  currency      String @default("usd")

  stripePaymentId  String?
  stripeTransferId String?
  status           PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([status])
}

model SupportTicket {
  id        String @id @default(cuid())
  creatorId String
  creator   User   @relation("TicketCreator", fields: [creatorId], references: [id])

  assigneeId String?
  assignee   User?   @relation("TicketAssignee", fields: [assigneeId], references: [id])

  subject     String
  description String
  status      TicketStatus @default(OPEN)
  priority    Int          @default(0)

  messages  TicketMessage[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([status])
}

model TicketMessage {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String
  message   String
  createdAt DateTime      @default(now())

  @@index([ticketId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model AiCreatorAnalysis {
  id        String  @id @default(cuid())
  creatorId String
  creator   Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  summary          String
  strengths        String[]
  weaknesses       String[]
  bestContentTypes String[]
  audienceInsights String?
  contentStyle     String?
  recommendedCpm   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId])
}

model AiDeliveryAnalysis {
  id         String @id @default(cuid())
  orderId    String
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliveryId String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  performanceSummary    String
  performanceScore      Int         // 0-100
  metricsBreakdown      String      // JSON string of metric-by-metric analysis
  briefAlignment        String      // how well the delivery matched the brief
  audienceEngagement    String      // analysis of engagement patterns
  strengths             String[]
  improvements          String[]
  whatsNext             String[]    // actionable next-step suggestions
  recommendedNextOrder  String?     // suggested next campaign type/approach

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([deliveryId])
}

model PlatformSettings {
  id              String @id @default("default")
  platformFeeRate Float  @default(0.15)
  minOrderBudget  Float  @default(5.00)
  maxOrderBudget  Float  @default(100000)
}

// ──── Agency & Account Manager ────

model Agency {
  id          String @id @default(cuid())
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName String
  website     String?
  description String?
  logo        String?

  managedBrands   AgencyBrand[]
  managedCreators AgencyCreator[]
  orders          Order[]
  accountManagerAgency AccountManagerAgency[]
  internalNotes   InternalNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgencyBrand {
  id       String @id @default(cuid())
  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  brandId  String
  brand    Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  status   String   @default("PENDING") // PENDING, APPROVED, REJECTED
  addedAt  DateTime @default(now())
  notes    String?

  @@unique([agencyId, brandId])
  @@index([agencyId])
  @@index([brandId])
}

model AgencyCreator {
  id        String  @id @default(cuid())
  agencyId  String
  agency    Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  creatorId String
  creator   Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())
  notes     String?

  @@unique([agencyId, creatorId])
  @@index([agencyId])
  @@index([creatorId])
}

model AccountManager {
  id         String @id @default(cuid())
  userId     String @unique
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  department String?

  assignedBrands   AccountManagerBrand[]
  assignedAgencies AccountManagerAgency[]
  internalNotes    InternalNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AccountManagerBrand {
  id               String         @id @default(cuid())
  accountManagerId String
  accountManager   AccountManager @relation(fields: [accountManagerId], references: [id], onDelete: Cascade)
  brandId          String
  brand            Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  assignedAt       DateTime       @default(now())
  priority         Int            @default(0)

  @@unique([accountManagerId, brandId])
  @@index([accountManagerId])
  @@index([brandId])
}

model AccountManagerAgency {
  id               String         @id @default(cuid())
  accountManagerId String
  accountManager   AccountManager @relation(fields: [accountManagerId], references: [id], onDelete: Cascade)
  agencyId         String
  agency           Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  assignedAt       DateTime       @default(now())
  priority         Int            @default(0)

  @@unique([accountManagerId, agencyId])
  @@index([accountManagerId])
  @@index([agencyId])
}

model InternalNote {
  id               String         @id @default(cuid())
  accountManagerId String
  accountManager   AccountManager @relation(fields: [accountManagerId], references: [id], onDelete: Cascade)

  brandId   String?
  brand     Brand?   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  agencyId  String?
  agency    Agency?  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  creatorId String?
  creator   Creator? @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([agencyId])
  @@index([creatorId])
  @@index([orderId])
  @@index([accountManagerId])
}
